```{r}
# Load necessary libraries
library(tidyverse)

# Step 1: Load the CSV file
data <- read.csv("total_speech_durations.csv")  # Replace with the actual path to your file

# Step 2: Remove ".csv" from the `filename` column, then split it into initial columns
data <- data %>%
  mutate(filename = gsub("\\.csv$", "", filename)) %>%  # Remove ".csv" extension
  separate(filename, into = c("speaker", "wizard_interaction", "condition"), sep = "_") %>%  # Split by underscores
  mutate(
    wizard_id = sub("([A-Z][0-9]+).*", "\\1", wizard_interaction), # Extract only W1 from W1P1
    interaction_id = sub(".*([A-Z][0-9]+)", "\\1", wizard_interaction) # Extract only P1 from W1P1
  ) %>%
  select(speaker, wizard_id, interaction_id, condition, total_speech_duration)  # Reorder columns

new_row_p = c(speaker = 'participant', wizard_id='W1', interaction_id='P3',condition='VR',speech_duration=NaN)
data = rbind(data,new_row_p)
new_row_r = c(speaker = 'robot', wizard_id='W1', interaction_id='P3',condition='VR',speech_duration=NaN)
data = rbind(data,new_row_r)
data <- data[order(data$speaker, data$wizard_id, data$interaction_id, data$condition),]
row.names(data) <- NULL

# Display the transformed data
print(data)

# Step 3: Save to a new CSV (optional)
write.csv(data, "reorganized_data.csv", row.names = FALSE)
```


```{r}
# Load necessary libraries
library(dplyr)
library(lme4)
library(lmerTest) 

# Load data
data <- read.csv("reorganized_data.csv")
data <- data %>%
  group_by(wizard_id, interaction_id) %>%
  mutate(user_id = cur_group_id()) %>%  # Assign unique ID per combination
  ungroup()

# Display the modified data
print(data)

# Convert columns to factors as needed
data$condition <- as.factor(data$condition)
data$speaker <- as.factor(data$speaker)
data$user_id <- as.factor(data$user_id)
```
```{r}
# Re-run the mixed-effects model with the corrected user IDs
model <- lmer(total_speech_duration ~ condition * speaker + (1 | wizard_id) + (1 | user_id), data = data)
summary(model)
```

