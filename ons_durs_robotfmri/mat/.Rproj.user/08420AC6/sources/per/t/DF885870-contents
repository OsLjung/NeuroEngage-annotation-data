```{r}
overlap_p2c_prod_data <- read.csv('overlaps_p2c_productive.csv')

overlap_p2c_prod_data <- overlap_p2c_prod_data %>%
  group_by(wizard_id, interaction_id) %>%
  mutate(user_id = cur_group_id()) %>%  # Assign unique ID per combination
  ungroup()

# Step 1: Create a count of overlaps per condition
overlap_counts <- overlap_p2c_prod_data %>%
  group_by(condition, wizard_id, user_id) %>%
  summarise(count = n()) %>%
  ungroup()

# Step 2: Fit a GLMM to see if overlap counts differ by condition
model <- glm(count ~ condition, 
               data = overlap_counts, 
               family = poisson(link = "log"))

# View model summary
summary(model)
