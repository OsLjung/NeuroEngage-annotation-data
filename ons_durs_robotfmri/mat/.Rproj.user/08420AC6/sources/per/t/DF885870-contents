# Step 1: Extract relevant columns and tag them
overlap_prod_data <- overlap_p2c_prod_data %>%
  select(wizard_id, interaction_id, condition) %>% # Adjust column names as per your actual data
  mutate(type = "overlap_prod") # Add a tag for overlaps

overlap_destr_data <- overlap_p2c_destr_data %>%
  select(wizard_id, interaction_id, condition) %>% # Adjust column names as per your actual data
  mutate(type = "overlap_destr") # Add a tag for overlaps

gap_data <- gaps_p2c_data %>%
  select(wizard_id, interaction_id, condition) %>% # Adjust column names as per your actual data
  mutate(type = "gap") # Add a tag for gaps

# Step 2: Combine the two data frames
all_transitions_p2c <- bind_rows(overlap_prod_data, overlap_destr_data, gap_data)
```

```{r}
proportion_overlap_prod <- all_transitions_p2c %>%
  group_by(wizard_id, interaction_id, condition, type) %>%
  summarise(count = n(), .groups = 'drop') %>% # Count occurrences and drop grouping afterwards
  pivot_wider(names_from = type, values_from = count, values_fill = 0) # Pivot to get overlaps and gaps in separate columns

# Step 2: Calculate total transitions and the proportion of overlaps
proportion_overlap_prod <- proportion_overlap_prod %>%
  mutate(total = overlap_prod + overlap_destr + gap, # Calculate total transitions
         proportion_overlap = overlap_prod / total)
